# ══════════════════════════════════════════════
# VOICEBOT STARTER — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env.local and add your key:
#   cp .env.example .env.local
#
# Get your API key: https://platform.openai.com/api-keys


OPENAI_API_KEY=your-api-key-here

# ── CHARACTER CONFIGURATION ──
# Change these to customize your bot's personality
BOT_NAME=Nova
BOT_PERSONA="You are Nova, a witty and helpful AI assistant. You speak clearly and concisely. You have a warm, friendly personality with a slight sense of humor."
TTS_VOICE=nova
# Available voices: alloy, echo, fable, onyx, nova, shimmer
